##########################################################################################
# Directories and files to exclude from inclusion in the Dynamic_NN Bit Bucket Repo
# ---------------------------------------------------------------------------------------
# This is a Juniper Project customized list of files not to be added to the git repo.
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore
##########################################################################################

# Environment files (secrets)
.env
.env.secrets

# Local Development directories
data/*
bin/*
cuda/*
temp/*
logs/*
images/*
# dynet-base/*/
# dynet-base/*.tgz
# dynet-base/*.zip
# dynet-base/*.tar.gz
# boost*/*
# src/pytorch_static/data/*
# torchexplorer_standalone/*
# **/reports
# **/reports/*
**/logs
**/backup
**/backups
**/temp
**/temp/*
**/resources/*

__pycache__
__pycache__/
__pycache__/*
**/__pycache__
**/__pycache__/
**/__pycache__/*

# Pytest cache
.pytest_cache/
**/.pytest_cache/

__init__.cpython*
**/__init__.cpython*

# CascadeCorrelationNetwork class snapshots
**/cascor/cascor_snapshots/*
cascor_snapshot_*.h5

# Sensitive files and dirs
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*/REAMDE.notes/*
*/encryption.bash
*/external_drive.readme

# Node artifact files
node_modules/
dist/

# Jupyter dirs
.ipynb_checkpoints/

# Data dirs
# data/
# data/*
data/MNIST/
data/MNIST/raw/

# Maven
target/
dist/

# Data files
*ubyte

# Compiled Java class files
*.class

# Python cProfile profiling files
*.prof

# Compiled Python bytecode
*.pyc
*.py[cod]
**/*.pyc

# Log files
*.log
**/*.log
*.out

# Package files
*.jar

# VSCode / Cursor IDE
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.trunk/
.trunk_new/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml
TEST*.html
TEST*.json

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Large Output Files
*.out
*.log
**/conf/tests_output.txt

# Generated by Linux
*.swq
*.swp
*.swo
*.swn
*.swm
*.swx
*.swy
*.swz

# Temp files
*.tmp
*.temp
.~lock.*

# Applications
*.app
*.exe
*.war

# Image Files
# *.png
*.jpg
*.jpeg
*.gif
*.pt
*.xcf

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# Archive files
*.gz
*.tgz
*.tar
*.bz
*.zip

# Package Files
*.deb
*.rpm
*.whl
*.tar.gz

# Build artifacts
*.egg-info/
**/*.egg-info/

# Coverage artifacts
.coverage
**/.coverage
coverage.xml
**/coverage.xml

# Test result artifacts
results.xml
**/results.xml

# Test reports and coverage reports
**/reports/
**/reports/**

# SERENA Memory Dirs
.serena
.serena/
.serena/*
.serena/**
**/.serena
**/.serena/
**/.serena/*
**/.serena/**

# Claude Code session files
__RESUME_CLAUDE_SESSION__

